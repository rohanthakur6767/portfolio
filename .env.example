# Required for live AI chatbot. Without this, the assistant falls back
# to demo responses (still works — never throws).
GEMINI_API_KEY=

# Optional. Override the Gemini model. Defaults to gemini-2.5-flash.
# (gemini-1.5-flash has been retired by Google.)
GEMINI_MODEL=

# Optional. Raises the GitHub API rate limit from 60/hr to 5000/hr.
# Create at https://github.com/settings/tokens (no scopes needed for public data).
GITHUB_TOKEN=

# Public site URL — used by sitemap, robots, and OG metadata.
NEXT_PUBLIC_SITE_URL=https://rohanthakur.dev
